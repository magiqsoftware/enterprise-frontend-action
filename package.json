{
  "name": "enterprise-frontend-action",
  "version": "1.0.5",
  "description": "Action that can be used across frontend sites to build and push to a bucket",
  "main": "dist/index.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "rm -rf ./dist && webpack",
    "lint": "eslint \"**/*.ts\" --ignore-pattern \"**/*.d.ts\" --quiet",
    "lint:fix": "eslint \"**/*.ts\" --ignore-pattern \"**/*.d.ts\" --fix --quiet"
  },
  "keywords": [
    "github",
    "actions",
    "enterprise",
    "frontend"
  ],
  "author": "MAGIQ Software Development",
  "license": "ISC",
  "dependencies": {
    "@actions/core": "^1.10.0",
    "@aws-sdk/credential-provider-sso": "^3.973.3",
    "aws-crt": "^1.32.2",
    "aws-sdk": "2.1693.0",
    "build": "^0.1.4",
    "compressing": "^1.6.2"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "@typescript-eslint/eslint-plugin": "^5.39.0",
    "@typescript-eslint/parser": "^5.39.0",
    "eslint": "^8.24.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-watch": "^8.0.0",
    "prettier": "^2.7.1",
    "ts-loader": "^9.6.2",
    "typescript": "^5.9.3",
    "webpack": "^5.108.4",
    "webpack-cli": "^4.10.0"
  }
}
